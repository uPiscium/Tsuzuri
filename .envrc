use flake

# =========================================================================
# 初回起動時の自動ブートストラップ機構
# =========================================================================
if grep -q '@@PROJECT_NAME@@' pyproject.toml; then
  # 1. カレントディレクトリ名を取得
  RAW_NAME=$(basename "$PWD")
  
  # 2. Pythonパッケージの命名規則（PEP 508）に適合するようにサニタイズ
  # （大文字を小文字に、英数字以外をハイフンに変換）
  SAFE_NAME=$(echo "$RAW_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_]/-/g')
  
  echo "==> Bootstrapping new project: $SAFE_NAME"
  
  # 3. Nixが提供するGNU sedで安全にインプレース置換
  sed -i "s/@@PROJECT_NAME@@/$SAFE_NAME/g" pyproject.toml
fi

# =========================================================================
# 環境の強制同期
# =========================================================================
if [ -f "pyproject.toml" ]; then
  uv sync
fi

source .venv/bin/activate
